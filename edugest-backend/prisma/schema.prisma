generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  ADMINISTRADOR
  DIRECTOR
  CAJERO
  DOCENTE
}

enum CategoriaDocumento {
  FOTO_ESTUDIANTE
  COMPROBANTE_PAGO
  DOCUMENTO_INSTITUCIONAL
  OTRO
}

model Usuario {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  nombre           String
  apellido         String
  ci               String    @unique
  role             Role      @default(ADMINISTRADOR)
  isActive         Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  docente        Docente?
  pagos          Pago[]
  notificaciones Notificacion[]
  documentos     Documento[]
  eventos        Evento[]
  auditLogs      AuditLog[]

  @@map("usuarios")
}

model PadreFamilia {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  ci        String   @unique
  telefono  String?
  email     String?
  createdAt DateTime @default(now())

  estudiantes Estudiante[]

  @@map("padres_familia")
}

model Estudiante {
  id          String   @id @default(uuid())
  nombre      String
  apellido    String
  ci          String   @unique
  fechaNac    DateTime
  foto        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  padreId     String
  padre       PadreFamilia  @relation(fields: [padreId], references: [id])
  inscripciones Inscripcion[]
  documentos  Documento[]

  @@map("estudiantes")
}

model Docente {
  id        String   @id @default(uuid())
  telefono  String?
  createdAt DateTime @default(now())

  usuarioId String   @unique
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  cursos    Curso[]

  @@map("docentes")
}

model Curso {
  id        String   @id @default(uuid())
  nombre    String
  nivel     String
  paralelo  String
  turno     String
  gestion   Int
  cupo      Int      @default(30)
  createdAt DateTime @default(now())

  docenteId    String?
  docente      Docente?      @relation(fields: [docenteId], references: [id])
  inscripciones Inscripcion[]

  @@map("cursos")
}

model Inscripcion {
  id        String   @id @default(uuid())
  gestion   Int
  estado    String   @default("ACTIVO")
  createdAt DateTime @default(now())

  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
  cursoId      String
  curso        Curso      @relation(fields: [cursoId], references: [id])

  pagos       Pago[]
  asistencias Asistencia[]

  @@unique([estudianteId, cursoId, gestion])
  @@map("inscripciones")
}

model Pago {
  id          String   @id @default(uuid())
  monto       Decimal
  metodoPago  String
  mes         String
  gestion     Int
  createdAt   DateTime @default(now())

  inscripcionId String
  inscripcion   Inscripcion @relation(fields: [inscripcionId], references: [id])
  cajeroId      String
  cajero        Usuario     @relation(fields: [cajeroId], references: [id])

  factura     Factura?

  @@map("pagos")
}

model Factura {
  id           String   @id @default(uuid())
  cuf          String   @unique
  nroFactura   Int
  estado       String   @default("PENDIENTE")
  pdfUrl       String?
  fechaEmision DateTime @default(now())

  pagoId       String   @unique
  pago         Pago     @relation(fields: [pagoId], references: [id])

  @@map("facturas")
}

model Asistencia {
  id     String   @id @default(uuid())
  fecha  DateTime
  estado String

  inscripcionId String
  inscripcion   Inscripcion @relation(fields: [inscripcionId], references: [id])

  @@map("asistencias")
}

model Notificacion {
  id        String   @id @default(uuid())
  titulo    String
  mensaje   String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@map("notificaciones")
}

model Documento {
  id        String             @id @default(uuid())
  nombre    String
  url       String
  publicId  String
  categoria CategoriaDocumento @default(OTRO)
  mimeType  String?
  size      Int?
  createdAt DateTime           @default(now())

  estudianteId String?
  estudiante   Estudiante? @relation(fields: [estudianteId], references: [id])
  subidoPorId  String?
  subidoPor    Usuario?    @relation(fields: [subidoPorId], references: [id])

  @@map("documentos")
}

model Evento {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String?
  fecha       DateTime
  lugar       String?
  createdAt   DateTime @default(now())

  creadoPorId String
  creadoPor   Usuario  @relation(fields: [creadoPorId], references: [id])

  @@map("eventos")
}

model AuditLog {
  id        String   @id @default(uuid())
  usuarioId String?
  accion    String
  modulo    String
  detalle   String?
  ip        String?
  createdAt DateTime @default(now())

  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("audit_logs")
}