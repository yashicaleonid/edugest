# Variables de entorno requeridas para EduGest

## Base de datos
DATABASE_URL=postgresql://usuario:password@localhost:5432/edugest

## JWT
JWT_SECRET=tu_secreto_jwt
JWT_EXPIRES_IN=1d

## Correo (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password

## Frontend (para enlaces de recuperación de contraseña)
FRONTEND_URL=http://localhost:5173

## Cloudinary (gestión documental)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

## API CUCU (facturación electrónica Bolivia)
# Si no se configuran, el sistema usa emisión simulada
CUCU_API_URL=https://api.cucu.bo/v1
CUCU_API_KEY=tu_api_key_cucu
